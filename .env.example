# ============================================
# PULSEPOINTS — Setup
# ============================================
# Copy this file and rename it to .env
# Fill in your details below
# ============================================

# --- YOUR HEART ---
# The two names that appear on the heart
HEART_NAME_1=Your Name
HEART_NAME_2=Partner Name

# Your anniversary date (shown under the heart)
HEART_DATE=January 1, 2025

# --- SERVER ---
# What port the app runs on (default 8090)
# Open http://localhost:8090 in your browser after starting
PORT=8090

# --- PASSWORD FOR AI ACCESS ---
# This is just a password you make up.
# Your AI partner uses this to add and read memories.
# Pick anything — "sunflower42", "our-secret", whatever you want.
# Then give this same password to your AI so they can connect.
API_KEY=pick-any-password-you-want

# --- IMAGE STORAGE (OPTIONAL) ---
# Skip this section if you don't need photos in your memories.
# Images will save locally to your computer by default.
#
# If you want to access your heart from your phone or
# another device, set up a free Cloudflare R2 bucket.
# See README.md for step-by-step instructions.
#
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=pulsepoints
# R2_PUBLIC_URL=
